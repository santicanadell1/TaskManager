@page "/gantt"
@using Service.Models
@using Service
@inject IJSRuntime JS
@inject AdminPService AdminPService
@inject TaskService TaskService
@inject CpmService CpmService
@inject GanttService GanttService
@rendermode InteractiveServer

<link href="/GanttLibrary/codebase/dhtmlxgantt.css" rel="stylesheet" />
<script src="/GanttLibrary/codebase/dhtmlxgantt.js"></script>

<h3>Gantt Chart</h3>

@if (projects == null || projects.Count == 0)
{
    <p>There are no projects for this user.</p>
}
else
{
    <label>Select a Project:</label>
    <select @onchange="OnProjectSelected"
            class="form-select"
            style="width: 300px; margin-bottom: 1rem;">
        <option disabled selected value="">-- Select a project --</option>
        @foreach (var p in projects)
        {
            <option value="@p.Name">@p.Name</option>
        }
    </select>
}


@if (showGantt)
{
    <div id="gantt_here" style="width:100%; height:80vh;"></div>
}

<script>
    window.initGantt = (ganttData) => {
        gantt.config.date_format = "%Y-%m-%d";
        gantt.config.show_progress = true;

        gantt.config.columns = [
            { name: "text",       label: "Task",     width: "*",   tree: true },
            { name: "start_date", label: "Start",    align: "center" },
            { name: "end_date",   label: "End",      align: "center" },
            { name: "duration",   label: "Duration", align: "center" },
            { name: "slack",      label: "Slack",    align: "center", template: t => t.slack },
            { name: "add",        label: "",         width: 44 }
        ];

        gantt.templates.task_class = (s, e, task) => task.critical ? "gantt_critical_task" : "";
        gantt.templates.link_class = link => link.critical ? "gantt_critical_link" : "";

        const style = document.createElement('style');
        style.innerHTML = `
            .gantt_critical_task .gantt_task_bar {
                background-color: #e74c3c !important;
                border: 1px solid #c0392b !important;
            }
            .gantt_critical_link {
                stroke: #c0392b !important;
                stroke-width: 2px !important;
            }
        `;
        document.head.appendChild(style);

        gantt.init("gantt_here");
        gantt.parse(ganttData);
    };
</script>

@code {
    private List<ProjectDTO> projects;
    private GanttData ganttData = new();
    private bool showGantt = false;
    
    private readonly string currentUserEmail = LoggedUser.Current.Email;
    
    protected override void OnInitialized()
    {
        projects = AdminPService
            .GetAllProjectsForUser(currentUserEmail)
            ?? new List<ProjectDTO>();
    }
    
    private async Task OnProjectSelected(ChangeEventArgs e)
    {
        var projectName = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(projectName))
            return;
        
        var tasks = TaskService.GetTasks(projectName);
        var cpm   = CpmService.CalculateCriticalPath(tasks);
        ganttData  = GanttService.Convert(tasks, cpm.CriticalPath);
        
        showGantt = true;
        StateHasChanged();
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) return;

        if (showGantt)
        {
            await JS.InvokeVoidAsync("initGantt", ganttData);
        }
    }
}
