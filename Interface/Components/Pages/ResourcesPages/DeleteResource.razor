@page "/resources/delete"
@using Service
@using Service.Models
@inject NavigationManager Navigation
@inject ResourceService ResourceService
@rendermode InteractiveServer

<h3>Delete Resource</h3>

<p>Select a resource to delete:</p>

<div class="mb-3">
    <select class="form-control" @bind="selectedResource">
        <option value="">-- Select Resource to Delete --</option>
        @foreach (var resource in resourcesList)
        {
            <option value="@resource">@resource.Name</option>
        }
    </select>
</div>

<button type="button" class="btn btn-danger" @onclick="DeleteResources" disabled="@(selectedResource == null)">
    Delete Resource
</button>

@code {
    private ResourceDTO? selectedResource;
    private List<ResourceDTO> resourcesList = new List<ResourceDTO>();

    protected override void OnInitialized()
    {
        try
        {
            resourcesList = ResourceService.GetResources();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading resources: {ex.Message}");
        }
    }

    private void DeleteResources()
    {
        if (selectedResource != null)
        {
            try
            {
                ResourceService.DeleteResource(selectedResource.Name, selectedResource.Type, selectedResource.Description);
                resourcesList = ResourceService.GetResources();
                Console.WriteLine($"Resource Deleted: {selectedResource.Name}");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting resource: {ex.Message}");
            }
        }

        selectedResource = null; // Limpiamos la selección después de eliminar
    }

}
