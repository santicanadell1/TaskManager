@page "/users/roles"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<link href="styles/styleAssignRol.css" rel="stylesheet"/>
<div class="assign-role-container">
    <h3>Assign Roles to User</h3>

    <!-- Dropdown or List of Users -->
    <div class="form-group">
        <label for="userSelect">Select a User</label>
        <select id="userSelect" class="form-control mt-1" @bind="selectedUserId">
            <option value="">-- Select a User --</option>
            @foreach (var user in usersList)
            {
                <option value="@user.Id">@user.FirstName @user.LastName</option>
            }
        </select>
    </div>

    <!-- Role Checkboxes -->
    <div class="form-group mt-3">
        <label>Select Roles</label>
        <br><br><br>
        <div class="form-check">
            <InputCheckbox id="adminSystem" class="form-check-input" @bind-Value="selectedRoles.AdminSystem"/>
            <label class="form-check-label" for="adminSystem">Admin System</label>
        </div>
        <div class="form-check">
            <InputCheckbox id="adminProject" class="form-check-input" @bind-Value="selectedRoles.AdminProyect"/>
            <label class="form-check-label" for="adminProject">Admin Project</label>
        </div>
        <div class="form-check">
            <InputCheckbox id="projectMember" class="form-check-input" @bind-Value="selectedRoles.ProyectMember"/>
            <label class="form-check-label" for="projectMember">Project Member</label>
        </div>
    </div>

    <!-- Assign Role Button -->
    <div class="form-group mt-3">
        <button type="button" class="btn btn-primary" @onclick="AssignRoles" disabled="@(!selectedUserId.HasValue)">
            Assign Role
        </button>
    </div>

    <!-- Display Success or Error Messages -->
    @if (assignError != null)
    {
        <div class="alert alert-danger">@assignError</div>
    }
    @if (assignSuccess != null)
    {
        <div class="alert alert-success">@assignSuccess</div>
    }
</div>

@code {

    private List<User> usersList = new()
    {
        new User { Id = 1, FirstName = "John", LastName = "Doe", Email = "john.doe@example.com" },
        new User { Id = 2, FirstName = "Jane", LastName = "Smith", Email = "jane.smith@example.com" },
        new User { Id = 3, FirstName = "Michael", LastName = "Brown", Email = "michael.brown@example.com" }
    };

    private int? selectedUserId;
    private string assignError;
    private string assignSuccess;

    // Object to hold the selected roles
    private UserRoles selectedRoles = new();

    private void AssignRoles()
    {
        var userToAssignRoles = usersList.FirstOrDefault(u => u.Id == selectedUserId);

        if (userToAssignRoles != null)
        {
            // Simulate role assignment
            userToAssignRoles.Roles = selectedRoles;

            assignSuccess = $"Roles have been assigned to {userToAssignRoles.FirstName} {userToAssignRoles.LastName} successfully.";
            selectedUserId = null;
            selectedRoles = new UserRoles(); // Reset roles selection after assignment
        }
        else
        {
            assignError = "User not found.";
        }
    }

    public class User
    {
        public int Id { get; set; }
        public string FirstName { get; set; }
        public string LastName { get; set; }
        public string Email { get; set; }
        public UserRoles Roles { get; set; } = new();
    }

    public class UserRoles
    {
        public bool AdminSystem { get; set; }
        public bool AdminProyect { get; set; }
        public bool ProyectMember { get; set; }
    }

}
