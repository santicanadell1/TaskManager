@page "/users/change-password"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<h3>Change User Password</h3>

<!-- Dropdown or List of Users -->
<div class="form-group">
    <label for="userSelect">Select a User</label>
    <select id="userSelect" class="form-control mt-1" @onchange="OnUserSelectionChanged">
        <option value="">-- Select a User --</option>
        @foreach (var user in usersList)
        {
            <option value="@user.Id">@user.FirstName @user.LastName</option>
        }
    </select>
</div>

@if (selectedUserId.HasValue)
{
    <!-- Old Password Input -->
    <div class="form-group mt-3">
        <label for="oldPassword">Old Password</label>
        <InputPassword id="oldPassword" class="form-control" @bind="oldPassword" required/>
    </div>

    <!-- New Password Input -->
    <div class="form-group mt-3">
        <label for="newPassword">New Password</label>
        <InputPassword id="newPassword" class="form-control" @bind="newPassword" required/>
    </div>

    <!-- Change Button -->
    <div class="form-group mt-3">
        <button type="button" class="btn btn-primary" @onclick="ChangesPassword" disabled="@(!IsPasswordValid)">Change
            Password
        </button>
    </div>

    <!-- Display Success or Error Messages -->
    @if (changeError != null)
    {
        <div class="alert alert-danger">@changeError</div>
    }

    @if (changeSuccess != null)
    {
        <div class="alert alert-success">@changeSuccess</div>
    }
}

@code {

    private List<User> usersList = new()
    {
        new User { Id = 1, FirstName = "John", LastName = "Doe", Email = "john.doe@example.com", Password = "oldPassword123" },
        new User { Id = 2, FirstName = "Jane", LastName = "Smith", Email = "jane.smith@example.com", Password = "oldPassword456" },
        new User { Id = 3, FirstName = "Michael", LastName = "Brown", Email = "michael.brown@example.com", Password = "oldPassword789" }
    };

    private int? selectedUserId; // Nullable to handle case when no user is selected
    private string oldPassword;
    private string newPassword;
    private string changeError;
    private string changeSuccess;

    // This property validates if the new password is different from the old one and not empty
    private bool IsPasswordValid => !string.IsNullOrEmpty(newPassword) && newPassword != oldPassword;

    // Method to reset password fields when a user is selected
    private void OnUserSelectionChanged(ChangeEventArgs e)
    {
        selectedUserId = int.TryParse(e.Value.ToString(), out var id) ? id : (int?)null;

        if (selectedUserId.HasValue)
        {
            var selectedUser = usersList.FirstOrDefault(u => u.Id == selectedUserId.Value);
            if (selectedUser != null)
            {
                oldPassword = selectedUser.Password;
                newPassword = string.Empty;
                changeError = null;
                changeSuccess = null;
            }
        }
        else
        {
            // Reset form if no user is selected
            oldPassword = string.Empty;
            newPassword = string.Empty;
            changeError = null;
            changeSuccess = null;
        }
    }

    // Method to handle password change
    private void ChangesPassword()
    {
        var userToChangePassword = usersList.FirstOrDefault(u => u.Id == selectedUserId);

        if (userToChangePassword != null && oldPassword == userToChangePassword.Password)
        {
            // Simulate changing the password
            userToChangePassword.Password = newPassword;
            changeSuccess = $"Password for {userToChangePassword.FirstName} {userToChangePassword.LastName} has been successfully changed.";

            // Reset the fields after successful change
            oldPassword = string.Empty;
            newPassword = string.Empty;
            selectedUserId = null;
        }
        else
        {
            changeError = "Old password is incorrect.";
        }
    }

    public class User
    {
        public int Id { get; set; }
        public string FirstName { get; set; }
        public string LastName { get; set; }
        public string Email { get; set; }
        public string Password { get; set; }
    }

}
