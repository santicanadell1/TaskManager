@page "/login"
@using System.ComponentModel.DataAnnotations
@inject NavigationManager Navigation
<h3 class="login-title">Login</h3>

<EditForm Model="loginModel" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator/>
    <ValidationSummary/>

    <!-- UserName Input -->
    <div class="form-group">
        <label for="userName">Username:</label>
        <!-- Explicitly set binding to the model -->
        <InputText id="userName" class="form-control mt-1" @bind-Value="loginModel.UserName"/>
    </div>

    <!-- Password Input -->
    <div class="form-group">
        <label for="password">Password:</label>
        <div class="input-password-wrapper">
            <!-- Bind password with model -->
            <InputText id="password"
                       type="@passwordInputType"
                       class="form-control mt-1"
                       @bind-Value="loginModel.Password"/>
            <!-- Toggle Button -->
            <button type="button" class="btn-eye" @onclick="TogglePasswordVisibility">
                <i class="@passwordEyeIcon"></i>
            </button>
        </div>
    </div>

    <!-- Submit Button -->
    <div class="form-group mt-3">
        <button type="submit" class="btn btn-primary">Login</button>
    </div>
    
    <div class="form-group mt-3">
        <a href="signup">Register</a>
    </div>

    <!-- Error Message -->
    @if (loginError != null)
    {
        <div class="alert alert-danger mt-3" role="alert">
            @loginError
        </div>
    }
</EditForm>

@code {
    private LoginModel loginModel = new LoginModel(); // Instantiate the model
    private string loginError;

    // Password visibility toggle
    private string passwordInputType = "password"; // Default: password element type
    private string passwordEyeIcon = "fas fa-eye-slash"; // Default: closed eye

    // Users list for testing
    private readonly List<User> users = new List<User>
    {
        new User { UserName = "admin", Password = "Admin123!", Role = "adminSystem" },
    };


    private void TogglePasswordVisibility()
    {
        if (passwordInputType == "password")
        {
            passwordInputType = "text";
            passwordEyeIcon = "fas fa-eye";
        }
        else
        {
            passwordInputType = "password";
            passwordEyeIcon = "fas fa-eye-slash";
        }
    }

    private void HandleValidSubmit()
    {
        var user = users.FirstOrDefault(u => u.UserName == loginModel.UserName && u.Password == loginModel.Password);

        if (user != null)
        {
            // Navigate based on role
            if (user.Role == "adminProyect")
                Navigation.NavigateTo("/admin-project");
            else if (user.Role == "adminSystem")
                Navigation.NavigateTo("/admin-system");
            else if (user.Role == "user")
                Navigation.NavigateTo("/user");
        }
        else
        {
            loginError = "Invalid username or password. Please try again.";
        }
    }

    private class LoginModel
    {
        [Required] public string UserName { get; set; } = string.Empty;

        [Required]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters long.")]
        public string Password { get; set; } = string.Empty;
    }

    private class User
    {
        public string UserName { get; set; }
        public string Password { get; set; }
        public string Role { get; set; }
    }

}