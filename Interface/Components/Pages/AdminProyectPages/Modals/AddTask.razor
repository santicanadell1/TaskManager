@inject NavigationManager Navigation
@rendermode InteractiveServer
@namespace ModalsProject

<!-- Modal -->
@if (IsVisible)
{
    <div class="modal fade show" tabindex="-1" style="display: block;" aria-labelledby="createTaskModal" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create Task</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            @errorMessage
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <div class="alert alert-success" role="alert">
                            @successMessage
                        </div>
                    }

                    <EditForm Model="@newTask" OnValidSubmit="HandleTaskSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label for="taskTitle" class="form-label">Task Title</label>
                            <InputText id="taskTitle" class="form-control" @bind-Value="newTask.Title" required />
                        </div>

                        <div class="mb-3">
                            <label for="taskDescription" class="form-label">Description</label>
                            <InputTextArea id="taskDescription" class="form-control" @bind-Value="newTask.Description" required />
                        </div>

                        <div class="mb-3">
                            <label for="startDate" class="form-label">Estimated Start Date</label>
                            <InputDate id="startDate" class="form-control" @bind-Value="newTask.StartDate" required />
                        </div>

                        <div class="mb-3">
                            <label for="duration" class="form-label">Duration (hours)</label>
                            <InputNumber id="duration" class="form-control" @bind-Value="newTask.Duration" required />
                        </div>

                        <!-- Resource Checklist -->
                        <div class="mb-3">
                            <label for="resources" class="form-label">Select Resources</label>
                            <div>
                                @foreach (var resource in availableResources)
                                {
                                    <div>
                                        <InputCheckbox id="@resource.Id" class="form-check-input" @bind-Value="resource.IsSelected" />
                                        <label class="form-check-label" for="@resource.Id">@resource.Name</label>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Previous Tasks and Dependency Type -->
                        <div class="mb-3">
                            <label for="previousTasks" class="form-label">Previous Tasks</label>
                            @foreach (var prevTask in previousTasks)
                            {
                                <div class="d-flex align-items-center">
                                    <select class="form-control" @bind="prevTask.SelectedTaskId">
                                        <option value="">-- Select Task --</option>
                                        @foreach (var task in taskList)
                                        {
                                            <option value="@task.Id">@task.Title</option>
                                        }
                                    </select>
                                    <select class="form-control ms-2" @bind="prevTask.DependencyType">
                                        <option value="FS">Finish-to-Start (FS)</option>
                                        <option value="SS">Start-to-Start (SS)</option>
                                    </select>
                                    <button class="btn btn-danger ms-2" @onclick="() => RemovePreviousTask(prevTask)">Remove</button>
                                </div>
                            }
                            <button class="btn btn-info mt-2" @onclick="AddPreviousTask">Add Previous Task</button>
                        </div>

                        <button type="submit" class="btn btn-success">Create Task</button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback<bool> OnClose { get; set; }
    [Parameter] public bool IsVisible { get; set; }

    private Task newTask = new Task();
    private List<Task> taskList = new List<Task>
    {
        new Task { Id = 1, Title = "Previous Task 1" },
        new Task { Id = 2, Title = "Previous Task 2" }
    };

    private List<Resource> availableResources = new List<Resource>
    {
        new Resource { Id = 1, Name = "Resource 1" },
        new Resource { Id = 2, Name = "Resource 2" }
    };

    private List<PreviousTask> previousTasks;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    // Método OnInitialized para inicializar el estado de previousTasks
    protected override void OnInitialized()
    {
        // Inicializar previousTasks con al menos una tarea vacía
        previousTasks = new List<PreviousTask>
        {
            new PreviousTask() // Al menos una tarea vacía
        };
    }

    // Método para añadir una nueva tarea previa
    private void AddPreviousTask()
    {
        errorMessage = string.Empty;  // Limpiar cualquier mensaje de error previo
        previousTasks.Add(new PreviousTask()); // Añadir una nueva tarea previa vacía
    }

    // Método para eliminar una tarea previa
    private void RemovePreviousTask(PreviousTask prevTask)
    {
        if (previousTasks.Count == 1)
        {
            // Mostrar mensaje de error si se intenta eliminar la última tarea
            errorMessage = "You must have at least one previous task.";
        }
        else
        {
            // Eliminar tarea previa y limpiar mensajes de error
            previousTasks.Remove(prevTask);
            errorMessage = string.Empty;
            EnsureAtLeastOnePreviousTask(); // Verificar que siempre quede al menos una tarea previa
        }
    }

    // Método para asegurarse de que siempre haya al menos una tarea previa
    private void EnsureAtLeastOnePreviousTask()
    {
        if (previousTasks.Count == 0)
        {
            previousTasks.Add(new PreviousTask()); // Agregar una tarea vacía si la lista está vacía
        }
    }

    private void CloseModal()
    {
        // Reseteamos las tareas previas y limpiamos los mensajes al cerrar el modal
        ResetPreviousTasks();
        OnClose.InvokeAsync(false);  // Cerrar el modal
    }

    private void HandleTaskSubmit()
    {
        // Lógica para manejar la creación de la tarea
        var selectedResources = availableResources.Where(r => r.IsSelected).Select(r => r.Id).ToList();
        Console.WriteLine($"Task Created: {newTask.Title}, Resources: {string.Join(", ", selectedResources)}, Dependencies: {string.Join(", ", previousTasks.Select(p => p.DependencyType))}");
        successMessage = "Task created successfully!";
        errorMessage = string.Empty;

        // Cerrar el modal después de crear la tarea
        CloseModal();
    }

    // Resetea las tareas previas cuando se cierra el modal
    private void ResetPreviousTasks()
    {
        previousTasks = new List<PreviousTask>
        {
            new PreviousTask() // Reinicia la lista con una tarea vacía
        };
        errorMessage = string.Empty; // Limpiar mensaje de error
        successMessage = string.Empty; // Limpiar mensaje de éxito
    }

    public class Task
    {
        public int Id { get; set; }
        public string Title { get; set; }
        public string Description { get; set; }
        public DateTime StartDate { get; set; }
        public int Duration { get; set; } // Duración en horas
    }

    public class Resource
    {
        public int Id { get; set; }
        public string Name { get; set; }
        public bool IsSelected { get; set; } // Para hacer seguimiento de la selección en el checklist
    }

    public class PreviousTask
    {
        public int? SelectedTaskId { get; set; }
        public string DependencyType { get; set; } // "FS" o "SS"
    }
}
