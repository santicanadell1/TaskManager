@using Service
@using Service.Models
@inject NavigationManager Navigation
@inject TaskService TaskService
@inject ResourceService ResourceService
@rendermode InteractiveServer
@namespace ModalsProject

@if (IsVisible)
{
    <div class="modal fade show" tabindex="-1" style="display: block;" aria-labelledby="createTaskModal"
         aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create Task</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            @errorMessage
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <div class="alert alert-success" role="alert">
                            @successMessage
                        </div>
                    }

                    <EditForm Model="@newTask" OnValidSubmit="HandleTaskSubmit">
                        <DataAnnotationsValidator/>
                        <ValidationSummary/>

                        <div class="mb-3">
                            <label for="taskTitle" class="form-label">Task Title</label>
                            <InputText id="taskTitle" class="form-control" @bind-Value="newTask.Title" required/>
                        </div>

                        <div class="mb-3">
                            <label for="taskDescription" class="form-label">Description</label>
                            <InputTextArea id="taskDescription" class="form-control" @bind-Value="newTask.Description"
                                           required/>
                        </div>

                        <div class="mb-3">
                            <label for="startDate" class="form-label">Estimated Start Date</label>
                            <InputDate id="startDate" class="form-control" @bind-Value="newTask.ExpectedStartDate"
                                       required/>
                        </div>

                        <div class="mb-3">
                            <label for="duration" class="form-label">Duration (hours)</label>
                            <InputNumber id="duration" class="form-control" @bind-Value="newTask.Duration" required/>
                        </div>

                        <!-- Resource Checklist -->
                        <div class="mb-3">
                            <label for="resources" class="form-label">Select Resources</label>
                            <div>
                                @foreach (var resource in availableResources)
                                {
                                    <div>
                                        <InputCheckbox id="@resource.Id" class="form-check-input"
                                                       @onchange="(e) => ToggleResourceSelection(e, resource.Id)"/>
                                        <label class="form-check-label" for="@resource.Id">@resource.Name</label>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Previous Tasks and Dependency Type -->
                        <div class="mb-3">
                            <label for="previousTasks" class="form-label">Previous Tasks</label>
                            @foreach (var prevTask in previousTasks)
                            {
                                <div class="d-flex align-items-center">
                                    <select class="form-control" @bind="prevTask.SelectedTaskId">
                                        <option value="">-- Select Task --</option>
                                        @foreach (var task in taskList)
                                        {
                                            <option value="@task.Id">@task.Title</option>
                                        }
                                    </select>
                                    <select class="form-control ms-2" @bind="prevTask.DependencyType">
                                        <option value="FS">Finish-to-Start (FS)</option>
                                        <option value="SS">Start-to-Start (SS)</option>
                                    </select>
                                    <button class="btn btn-danger ms-2" @onclick="() => RemovePreviousTask(prevTask)">
                                        Remove
                                    </button>
                                </div>
                            }
                            <button class="btn btn-info mt-2" @onclick="AddPreviousTask">Add Previous Task</button>
                        </div>

                        <button type="submit" class="btn btn-success">Create Task</button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback<bool> OnClose { get; set; }
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public ProjectDTO SelectedProject { get; set; }

    private Service.Models.TaskDTO newTask = new Service.Models.TaskDTO();
    private List<Service.Models.TaskDTO> taskList = new List<Service.Models.TaskDTO>();
    private List<Service.Models.ResourceDTO> availableResources = new List<Service.Models.ResourceDTO>();
    private List<PreviousTask> previousTasks = new List<PreviousTask>();
    private HashSet<int> selectedResourceIds = new HashSet<int>(); // Para llevar el seguimiento de los recursos seleccionados
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    // Listas para tareas previas FS y SS
    private List<Service.Models.TaskDTO> previousTasksFS = new List<Service.Models.TaskDTO>(); // Lista para tareas previas FS
    private List<Service.Models.TaskDTO> sameTimeTasksSS = new List<Service.Models.TaskDTO>(); // Lista para tareas simultáneas SS

    protected override void OnInitialized()
    {
        LoadResources();
        LoadTasks();
    }

    private void LoadResources()
    {
        try
        {
            availableResources = ResourceService.GetResources(); // Llamamos al servicio para obtener los recursos
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading resources: {ex.Message}";
        }
    }

    private void LoadTasks()
    {
        try
        {
            taskList = TaskService.GetTasks(SelectedProject.Name); // Llamamos al servicio para obtener las tareas
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading tasks: {ex.Message}";
        }
    }

    private void ToggleResourceSelection(ChangeEventArgs e, int? resourceId)
    {
        if (e.Value is bool isSelected)
        {
            if (isSelected)
            {
                selectedResourceIds.Add(resourceId); // Añadir a la lista de recursos seleccionados
            }
            else
            {
                selectedResourceIds.Remove(resourceId); // Eliminar de la lista de recursos seleccionados
            }
        }
    }

    private void AddPreviousTask()
    {
        errorMessage = string.Empty;
        previousTasks.Add(new PreviousTask());
    }

    private void RemovePreviousTask(PreviousTask prevTask)
    {
        if (previousTasks.Count == 1)
        {
            errorMessage = "You must have at least one previous task.";
        }
        else
        {
            previousTasks.Remove(prevTask);
            errorMessage = string.Empty;
            EnsureAtLeastOnePreviousTask();
        }
    }

    private void EnsureAtLeastOnePreviousTask()
    {
        if (previousTasks.Count == 0)
        {
            previousTasks.Add(new PreviousTask());
        }
    }

    private void CloseModal()
    {
        ResetPreviousTasks();
        OnClose.InvokeAsync(false);
    }

    private void HandleTaskSubmit()
    {
        // Limpiar las listas de tareas previas FS y SS
        previousTasksFS.Clear();
        sameTimeTasksSS.Clear();

        // Asignamos las tareas previas en las listas correspondientes
        foreach (var prevTask in previousTasks)
        {
            if (prevTask.DependencyType == "FS")
            {
                // Agregar a PreviousTasks (FS)
                previousTasksFS.Add(new Service.Models.TaskDTO
                {
                    Id = prevTask.SelectedTaskId ?? 0, // Asignar el ID de la tarea seleccionada
                });
            }
            else if (prevTask.DependencyType == "SS")
            {
                // Agregar a SameTimeTasks (SS)
                sameTimeTasksSS.Add(new Service.Models.TaskDTO
                {
                    Id = prevTask.SelectedTaskId ?? 0, // Asignar el ID de la tarea seleccionada
                });
            }
        }

        // Asignamos las listas de tareas previas y simultáneas a la tarea creada
        newTask.PreviousTasks = previousTasksFS;
        newTask.SameTimeTasks = sameTimeTasksSS;

        successMessage = "Task created successfully!";
        errorMessage = string.Empty;

        // Asignamos la tarea a través del servicio TaskService
        TaskService.AddTask(SelectedProject.Name, newTask); // Llamamos al servicio para agregar la tarea

        CloseModal();
    }

    private void ResetPreviousTasks()
    {
        previousTasks = new List<PreviousTask> { new PreviousTask() };
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }

    public class PreviousTask
    {
        public int? SelectedTaskId { get; set; }
        public string DependencyType { get; set; } // "FS" o "SS"
    }

}
