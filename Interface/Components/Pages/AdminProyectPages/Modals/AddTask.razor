@using Service
@using Service.Models
@inject NavigationManager Navigation
@inject TaskService TaskService
@inject ResourceService ResourceService
@rendermode InteractiveServer
@namespace ModalsProject

@if (IsVisible)
{
    <div class="modal fade show" tabindex="-1" style="display: block;" aria-labelledby="createTaskModal"
         aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create Task</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            @errorMessage
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <div class="alert alert-success" role="alert">
                            @successMessage
                        </div>
                    }

                    <EditForm Model="@newTask" OnValidSubmit="HandleTaskSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label for="taskTitle" class="form-label">Task Title</label>
                            <InputText id="taskTitle" class="form-control" @bind-Value="newTask.Title" required />
                        </div>

                        <div class="mb-3">
                            <label for="taskDescription" class="form-label">Description</label>
                            <InputTextArea id="taskDescription" class="form-control" @bind-Value="newTask.Description" required />
                        </div>

                        <div class="mb-3">
                            <label for="startDate" class="form-label">Estimated Start Date</label>
                            <InputDate id="startDate" class="form-control" @bind-Value="newTask.ExpectedStartDate" required />
                        </div>

                        <div class="mb-3">
                            <label for="duration" class="form-label">Duration (hours)</label>
                            <InputNumber id="duration" class="form-control" @bind-Value="newTask.Duration" required />
                        </div>

                        <!-- Resource Checklist -->
                        <div class="mb-3">
                            <label for="resources" class="form-label">Select Resources</label>
                            <div>
                                @foreach (var resource in availableResources)
                                {
                                    <div>
                                        <InputCheckbox id="@resource.Id" class="form-check-input"
                                                       @onchange="(e) => ToggleResourceSelection(e, resource.Id)" />
                                        <label class="form-check-label" for="@resource.Id">@resource.Name</label>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Previous Tasks and Dependency Type -->
                        <div class="mb-3">
                            <label for="previousTasks" class="form-label">Previous Tasks</label>
                            @for (int i = 0; i < previousTaskIds.Count; i++)
                            {
                                <div class="d-flex align-items-center">
                                    <select class="form-control" @bind="previousTaskIds[i]">
                                        <option value="">-- Select Task --</option>
                                        @foreach (var task in taskList)
                                        {
                                            <option value="@task.Id">@task.Title</option>
                                        }
                                    </select>
                                    <select class="form-control ms-2" @bind="previousTaskDependencies[i]">
                                        <option value="FS">Finish-to-Start (FS)</option>
                                        <option value="SS">Start-to-Start (SS)</option>
                                    </select>
                                    <button class="btn btn-danger ms-2" @onclick="() => RemovePreviousTask(i)">
                                        Remove
                                    </button>
                                </div>
                            }
                            <button class="btn btn-info mt-2" @onclick="AddPreviousTask">Add Previous Task</button>
                        </div>

                        <button type="submit" class="btn btn-success">Create Task</button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback<bool> OnClose { get; set; }
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public ProjectDTO SelectedProject { get; set; }

    private TaskDTO newTask = new TaskDTO();
    private List<TaskDTO> taskList = new List<TaskDTO>();
    private List<ResourceDTO> availableResources = new List<ResourceDTO>();

    // Listas para almacenar TaskId y DependencyType
    private List<int?> previousTaskIds = new List<int?>();
    private List<string> previousTaskDependencies = new List<string>();

    private HashSet<int?> selectedResourceIds = new HashSet<int?>();
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    protected override void OnInitialized()
    {
        LoadResources();
        LoadTasks();
    }

    private void LoadResources()
    {
        try
        {
            availableResources = ResourceService.GetResources();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading resources: {ex.Message}";
        }
    }

    private void LoadTasks()
    {
        try
        {
            taskList = TaskService.GetTasks(SelectedProject.Name);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading tasks: {ex.Message}";
        }
    }

    private void ToggleResourceSelection(ChangeEventArgs e, int? resourceId)
    {
        if (e.Value is bool isSelected)
        {
            if (isSelected)
            {
                selectedResourceIds.Add(resourceId);
            }
            else
            {
                selectedResourceIds.Remove(resourceId);
            }
        }
    }

    private void AddPreviousTask()
    {
        previousTaskIds.Add(null); // Add an empty task ID
        previousTaskDependencies.Add("FS"); // Default to "Finish-to-Start"
    }

    private void RemovePreviousTask(int index)
    {
        if (previousTaskIds.Count > 1)
        {
            previousTaskIds.RemoveAt(index);
            previousTaskDependencies.RemoveAt(index);
        }
        else
        {
            errorMessage = "You must have at least one previous task.";
        }
    }

    private void CloseModal()
    {
        OnClose.InvokeAsync(false);
    }

    private void HandleTaskSubmit()
    {
        var previousTasksFS = new List<TaskDTO>();
        var sameTimeTasksSS = new List<TaskDTO>();

        for (int i = 0; i < previousTaskIds.Count; i++)
        {
            if (previousTaskDependencies[i] == "FS")
            {
                previousTasksFS.Add(new TaskDTO { Id = previousTaskIds[i] ?? 0 });
            }
            else if (previousTaskDependencies[i] == "SS")
            {
                sameTimeTasksSS.Add(new TaskDTO { Id = previousTaskIds[i] ?? 0 });
            }
        }

        newTask.PreviousTasks = previousTasksFS;
        newTask.SameTimeTasks = sameTimeTasksSS;

        successMessage = "Task created successfully!";
        errorMessage = string.Empty;

        TaskService.AddTask(SelectedProject.Name, newTask);

        CloseModal();
    }
}
