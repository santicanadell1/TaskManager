@using Service.Models
@inject AdminPService AdminPService
@inject NavigationManager Navigation
@rendermode InteractiveServer
@namespace ModalsProject

@if (IsVisible)
{
    <div class="modal fade show" tabindex="-1" style="display: block;" aria-labelledby="addMembersModal"
         aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Members</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <h6>Select Members to Add</h6>
                    <div class="mb-3">
                        @foreach (var member in membersList)
                        {
                            <div class="form-check">
                                <InputCheckbox id="@member.Id" class="form-check-input"
                                               @bind-Value="member.IsSelected"/>
                                <label class="form-check-label" for="@member.Id">
                                    @member.Name
                                </label>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                    <button type="button" class="btn btn-primary" @onclick="AddSelectedMembers">Add Members</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback<bool> OnClose { get; set; }
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public ProjectDTO SelectedProject { get; set; }

    private List<Service.Models.UserDTO> membersList = new List<Service.Models.UserDTO>
    {
        new Service.Models.UserDTO { FirstName = "John", LastName = "Doe", Email = "john.doe@example.com" },
        new Service.Models.UserDTO { FirstName = "Jane", LastName = "Smith", Email = "jane.smith@example.com" },
        new Service.Models.UserDTO { FirstName = "Michael", LastName = "Brown", Email = "michael.brown@example.com" },
        new Service.Models.UserDTO { FirstName = "Lisa", LastName = "White", Email = "lisa.white@example.com" }
    };

    private void CloseModal()
    {
        ResetMemberSelections();
        OnClose.InvokeAsync(false);
    }

    private void AddSelectedMembers()
    {
        var selectedMembers = membersList.Where(m => m.IsSelected).ToList();

        if (selectedMembers.Any())
        {
            try
            {
                AdminPService.AssignMembersToProject(SelectedProject.Name, selectedMembers);
                Console.WriteLine("Members added successfully!");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error adding members: {ex.Message}");
            }
        }

        CloseModal();
    }

    private void ResetMemberSelections()
    {
        foreach (var member in membersList)
        {
            member.IsSelected = false;
        }
    }

}
