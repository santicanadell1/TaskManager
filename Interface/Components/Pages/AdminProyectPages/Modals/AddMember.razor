@using Service.Models
@inject AdminPService AdminPService
@inject NavigationManager Navigation
@rendermode InteractiveServer
@namespace ModalsProject

<link href="styles/styleModalsAdminProject.css" rel="stylesheet"/>

@if (IsVisible)
{
    <div class="modal fade show" tabindex="-1" style="display: block;" aria-labelledby="addMembersModal"
         aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Members</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <h6>Select Members to Add</h6>
                    <div class="mb-3">
                        @foreach (var member in membersList)
                        {
                            <div class="form-check">
                                <InputCheckbox id="@member.Email" class="form-check-input"
                                               @onchange="(e) => ToggleSelection(e, member.Email)"/>
                                <label class="form-check-label" for="@member.Email">
                                    @member.FirstName @member.LastName
                                </label>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                    <button type="button" class="btn btn-primary" @onclick="AddSelectedMembers">Add Members</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback<bool> OnClose { get; set; }
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public ProjectDTO SelectedProject { get; set; }
    [Parameter] public List<UserDTO> membersList { get; set; }

    private HashSet<string> selectedEmails = new HashSet<string>();

    private void CloseModal()
    {
        ResetMemberSelections();
        OnClose.InvokeAsync(false);
    }

    private void ToggleSelection(ChangeEventArgs e, string email)
    {
        if (e.Value is bool isSelected)
        {
            if (isSelected)
            {
                selectedEmails.Add(email);
            }
            else
            {
                selectedEmails.Remove(email);
            }
        }
    }

    private void AddSelectedMembers()
    {
        var selectedMembers = membersList.Where(m => selectedEmails.Contains(m.Email)).ToList();

        if (selectedMembers.Any())
        {
            try
            {
                AdminPService.AssignMembersToProject(SelectedProject.Name, selectedMembers);
                Console.WriteLine("Members added successfully!");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error adding members: {ex.Message}");
            }
        }

        CloseModal();
    }

    private void ResetMemberSelections()
    {
        selectedEmails.Clear();
    }

}
