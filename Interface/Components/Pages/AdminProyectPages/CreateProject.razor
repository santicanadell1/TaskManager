@page "/project/create"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<div class="create-project-page">

    <EditForm Model="@newProject" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="projectName" class="form-label">Project Name</label>
            <InputText id="projectName" class="form-control" @bind-Value="newProject.Name" required />
        </div>

        <div class="mb-3">
            <label for="projectDescription" class="form-label">Description (max. 400 characters)</label>
            <InputTextArea id="projectDescription" class="form-control" @bind-Value="newProject.Description" MaxLength="400" required />
        </div>

        <div class="mb-3">
            <label for="startDate" class="form-label">Estimated Start Date</label>
            <InputDate id="startDate" class="form-control" @bind-Value="newProject.StartDate" required />
        </div>

        <button type="submit" class="btn btn-primary">Create Project</button>
    </EditForm>
</div>

@code {
    private Project newProject = new Project();

    private void HandleValidSubmit()
    {
        // Lógica para manejar la creación del proyecto (guardar en base de datos o backend)
        Console.WriteLine("Project Created: " + newProject.Name);
        Navigation.NavigateTo("/projects");
    }

    public class Project
    {
        public string Name { get; set; }
        public string Description { get; set; }
        public DateTime StartDate { get; set; }
    }
}
