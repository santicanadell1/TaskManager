@page "/resource-panel"
@using Controllers
@using Microsoft.JSInterop
@using Service.Models
@inject ResourceAdminController _ResourceAdminController
@inject AdminProjectController   _AdminProjectController
@inject IJSRuntime                JS
@rendermode InteractiveServer

<div class="container my-4">
    <h3 class="mb-4"><i class="bi bi-calendar3 me-2"></i>Panel de Recursos</h3>

    <div class="row mb-3">
        <div class="col-md-4">
            <label>Proyecto:</label>
            <select class="form-select" @onchange="OnProjectChanged">
                <option value="">-- Selecciona un proyecto --</option>
                @foreach (var p in _projects)
                {
                <option value="@p.Name">@p.Name</option>
                }
            </select>
        </div>
        @if (!string.IsNullOrEmpty(_selectedProject))
        {
        <div class="col-md-4">
            <label>Recurso:</label>
            <select class="form-select" @onchange="OnResourceChanged">
                <option value="">-- Selecciona un recurso --</option>
                @foreach (var r in _resources)
                {
                <option value="@r.Id">@r.Name</option>
                }
            </select>
        </div>
        }
    </div>

    @if (_showCalendar)
    {
    <div id="resourceCalendar"></div>
    }
</div>

@code {
private List<ProjectDTO>  _projects       = new();
private List<ResourceDTO> _resources      = new();
private string            _selectedProject;
private ResourceDTO       _selectedResource;
private bool              _showCalendar   = false;

protected override void OnInitialized()
{
var currentEmail = LoggedUser.Current.Email;
_projects = _AdminProjectController
.GetAllProjectsForUser(currentEmail)
?? new List<ProjectDTO>();
}

private void OnProjectChanged(ChangeEventArgs e)
{
_selectedProject = e.Value?.ToString();
_showCalendar   = false;
_resources      = string.IsNullOrEmpty(_selectedProject)
? new List<ResourceDTO>()
: _ResourceAdminController
.getAllResourcesForAProject(_selectedProject);
}

private async Task OnResourceChanged(ChangeEventArgs e)
{
if (!int.TryParse(e.Value?.ToString(), out var resId))
{
_showCalendar = false;
return;
}

_selectedResource = _resources.First(r => r.Id == resId);

var occupied = _ResourceAdminController
.getWhenIsResourceOcupied(_selectedResource);
var nextFree = _ResourceAdminController
.NextDateAvailable(_selectedResource, DateTime.Today, 1);
var events = new List<object>();
foreach (var (start, dur) in occupied)
{
events.Add(new {
title = "Ocupado",
start = start.ToString("yyyy-MM-dd"),
end   = start.AddDays(dur).ToString("yyyy-MM-dd"),
color = "red"
});
}

events.Add(new {
title = "Libre",
start = nextFree.ToString("yyyy-MM-dd"),
end   = nextFree.AddDays(1).ToString("yyyy-MM-dd"),
color = "green"
});

await JS.InvokeVoidAsync("initResourceCalendar", events);

_showCalendar = true;
}
}
