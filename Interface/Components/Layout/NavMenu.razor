@using Service
@inject Login LoginService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">TaskTrackPro</a>
    </div>
</div>

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        @if (LoginService.GetLoggedUser() == null)
        {
            <!-- If the user is not logged in, show Login and Sign Up -->
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/login">
                    <span aria-hidden="true"></span> Login
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/signup">
                    <span aria-hidden="true"></span> Sign Up
                </NavLink>
            </div>
        }
        else
        {
            <!-- User icon that leads to the login page if user is logged in -->
            <div class="nav-item px-3">
                <button class="btn btn-link" @onclick="Logout">
                    <i class="bi bi-box-arrow-right" style="font-size: 24px; color: white;"></i>
                </button>
            </div>

            <!-- If the user is logged in, show the navigation items -->

            <AdminNav/>
            <ResourcesNav/>
        }
    </nav>
</div>

@code {

    private void NavigateToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private void Logout()
    {
        LoginService.Logout();
        Navigation.NavigateTo("/login");
    }

}
